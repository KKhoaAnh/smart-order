# ============================================================
# Smart Order QR — Environment Variables
# Copy file này thành .env và điền giá trị phù hợp
# ============================================================

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=smart_order_user
DB_PASSWORD=smart_order_pass_2026
DB_DATABASE=smart_order_db

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-too
JWT_REFRESH_EXPIRES_IN=7d

# ── API Server ──
API_PORT=3001
API_PREFIX=api

# ── CORS ──
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# ── Frontend (Customer App) ──
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ── Frontend (POS App) ──
# POS app cũng dùng NEXT_PUBLIC_API_URL và NEXT_PUBLIC_SOCKET_URL ở trên

# ── Node Environment ──
NODE_ENV=development
